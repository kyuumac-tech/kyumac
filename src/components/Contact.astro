      <!-- Contact Form -->
      <div class="bg-gray-50 p-8 rounded-3xl">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Kirim Pesan</h3>
        <form id="contact-form" class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Nama Lengkap</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" placeholder="Masukkan nama Anda" />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Nomor WhatsApp</label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" placeholder="08xx-xxxx-xxxx (opsional)" />
          </div>

          <div>
            <label for="service" class="block text-sm font-medium text-gray-700 mb-2">Jenis Layanan</label>
            <select id="service" name="service" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all">
              <option value="">Pilih layanan</option>
              <option value="Service Mati Total">Service Mati Total</option>
              <option value="Ganti LCD/Display">Ganti LCD/Display</option>
              <option value="Ganti Keyboard">Ganti Keyboard</option>
              <option value="Ganti Trackpad">Ganti Trackpad</option>
              <option value="Ganti TouchBar">Ganti TouchBar</option>
              <option value="Ganti Speaker">Ganti Speaker</option>
              <option value="Ganti Baterai">Ganti Baterai</option>
              <option value="Beli Macbook Bekas">Beli Macbook Bekas</option>
              <option value="Jual Macbook">Jual Macbook</option>
              <option value="Lainnya">Lainnya</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Pesan / Keluhan</label>
            <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all resize-none" placeholder="Jelaskan kebutuhan atau masalah Macbook Anda"></textarea>
          </div>

          <button type="submit" class="w-full px-6 py-4 text-base font-medium rounded-xl text-white bg-blue-600 hover:bg-blue-700 transition-colors flex items-center justify-center">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Kirim via WhatsApp
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const name = formData.get('name') as string;
    const phone = formData.get('phone') as string;
    const service = formData.get('service') as string;
    const message = formData.get('message') as string;
    
    // Format pesan WhatsApp
    let waMessage = `Halo KyuuMac, saya mau konsultasi:\n\n`;
    waMessage += `*Nama:* ${name}\n`;
    if (phone) waMessage += `*No. WA:* ${phone}\n`;
    waMessage += `*Layanan:* ${service}\n`;
    waMessage += `*Pesan:*\n${message}`;
    
    // Encode dan redirect ke WhatsApp
    const waUrl = `https://wa.me/6285117101318?text=${encodeURIComponent(waMessage)}`;
    window.open(waUrl, '_blank');
    
    // Reset form
    form.reset();
  });
</script>
