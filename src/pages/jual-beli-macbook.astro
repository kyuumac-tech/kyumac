---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

// Data MacBook untuk dijual (nanti bisa dipindah ke database/CMS)
// Gambar dari Unsplash (free to use)
const macbooks = [
  {
    id: 1,
    name: 'MacBook Air M1 2020',
    specs: '8GB RAM | 256GB SSD',
    price: 'Rp 9.500.000',
    condition: '95% Mulus',
    status: 'sold',
    image: 'https://images.unsplash.com/photo-1611186871348-b1ce696e52c9?w=800&q=80', // MacBook Air Silver
    details: 'Battery health 95%, No dent, Fullset box'
  },
  {
    id: 2,
    name: 'MacBook Pro 13" M1 2020',
    specs: '8GB RAM | 512GB SSD',
    price: 'Rp 13.500.000',
    condition: '90% Bagus',
    status: 'sold',
    image: 'https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=800&q=80', // MacBook Pro
    details: 'Battery health 88%, Minus lecet tipis body, Fullset'
  },
  {
    id: 3,
    name: 'MacBook Air M2 2022',
    specs: '8GB RAM | 256GB SSD | Midnight',
    price: 'Rp 14.500.000',
    condition: '98% Like New',
    status: 'sold',
    image: 'https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=800&q=80', // MacBook Dark
    details: 'Battery health 100%, Garansi resmi 6 bulan'
  },
  {
    id: 4,
    name: 'MacBook Pro 14" M1 Pro 2021',
    specs: '16GB RAM | 512GB SSD | Space Gray',
    price: 'Rp 21.000.000',
    condition: '92% Excellent',
    status: 'sold',
    image: 'https://images.unsplash.com/photo-1541807084-5c52b6b3adef?w=800&q=80', // MacBook workspace
    details: 'Battery cycle 50x, Fullset box + charger original'
  },
  {
    id: 5,
    name: 'Mac Mini M4 2024',
    specs: '16GB RAM | 256GB SSD',
    price: 'Rp 9.500.000',
    condition: '98% Like New',
    status: 'sold',
    image: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=800&q=80', // Mac Mini
    details: 'Battery cycle N/A, Compact desktop Mac terbaru'
  },
  {
    id: 6,
    name: 'iMac M1 24" 2021',
    specs: '8GB RAM | 256GB SSD | Blue',
    price: 'Rp 14.000.000',
    condition: '95% Excellent',
    status: 'sold',
    image: 'https://images.unsplash.com/photo-1531297484001-80022131f5a1?w=800&q=80', // iMac
    details: 'Display 4.5K Retina, Magic Keyboard + Mouse included'
  }
