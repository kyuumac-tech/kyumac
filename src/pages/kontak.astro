---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
  title="Kontak KyuuMac - Service MacBook Jogja"
  description="Hubungi KyuuMac untuk konsultasi service MacBook & iMac di Jogja. WhatsApp: +62 851-1710-1318, Email: kyuumac@gmail.com. Buka Senin-Minggu."
>
  <Header />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-blue-50 to-white">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
        Hubungi Kami
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Konsultasi gratis untuk semua kebutuhan MacBook & iMac Anda
      </p>
    </div>
  </section>

  <!-- Contact Component -->
  <Contact />

  <!-- Map Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Lokasi Kami</h2>
      <div class="rounded-3xl overflow-hidden shadow-2xl">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d15813.273939177425!2d110.3936925!3d-7.7548922!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e7a59e22ee43a31%3A0x8c2e89d2e2f2c8e0!2sKyuuMac!5e0!3m2!1sen!2sid!4v1738239543210!5m2!1sen!2sid"
          width="100%" 
          height="450" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="w-full"
        ></iframe>
      </div>
      <div class="mt-8 text-center">
        <p class="text-gray-600 mb-4">
          <strong class="text-gray-900">Alamat:</strong> Gg. Cucak Rowo Jl. Plemburan No.6, Sedan, Sariharjo, Kec. Ngaglik, Kabupaten Sleman, Daerah Istimewa Yogyakarta 55581
        </p>
        <a 
          href="https://maps.app.goo.gl/AAsShsuNsJNBXXS39" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-6 py-3 bg-[#0071e3] hover:bg-[#0077ED] text-white font-medium rounded-xl transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          Buka di Google Maps
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppButton />
</Layout>
