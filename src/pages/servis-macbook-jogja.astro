---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Services from '../components/Services.astro';
import SpareParts from '../components/SpareParts.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
  title="Servis MacBook Jogja Terpercaya - Service & Perbaikan MacBook | KyuuMac"
  description="Servis MacBook Jogja profesional & terpercaya. Spesialis perbaikan mati total, ganti LCD Retina, keyboard, baterai, dll. Garansi 1 bulan harga terjangkau."
>
  <Header />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-blue-50 to-white">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
        Layanan Service MacBook & iMac Jogja
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
        Solusi lengkap untuk semua kebutuhan perbaikan MacBook & iMac Anda dengan teknisi berpengalaman
      </p>
      <a href="https://wa.me/6285117101318?text=Halo%20KyuuMac%2C%20saya%20mau%20konsultasi%20service" class="inline-flex items-center px-8 py-4 text-base font-medium rounded-full text-white bg-blue-600 hover:bg-blue-700 transition-colors">
        Konsultasi Gratis
      </a>
    </div>
  </section>

  <!-- Services Component -->
  <Services />

  <!-- Spare Parts Component -->
  <SpareParts />

