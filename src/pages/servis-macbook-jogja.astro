  <!-- Service Schema Markup -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Servis MacBook",
    "provider": {
      "@type": "LocalBusiness",
      "name": "KyuuMac",
      "image": "https://kyuumac.com/favicon.svg",
      "telephone": "+6285117101318",
