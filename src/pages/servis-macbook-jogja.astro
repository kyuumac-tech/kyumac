      <!-- Gallery Grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <div class="group relative overflow-hidden rounded-2xl aspect-square">
          <img 
            src="/servis-macbook-11.jpeg" 
