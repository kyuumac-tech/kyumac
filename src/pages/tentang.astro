---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import WhyUs from '../components/WhyUs.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
  title="Tentang KyuuMac - Service MacBook Terpercaya Jogja"
  description="KyuuMac adalah service center MacBook & iMac terpercaya di Jogja dengan teknisi berpengalaman. Komitmen kami memberikan layanan terbaik untuk perangkat Apple Anda."
>
  <Header />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
            Tentang KyuuMac
          </h1>
          <p class="text-xl text-gray-600 mb-6">
            Service center MacBook & iMac terpercaya di Yogyakarta dengan pengalaman bertahun-tahun melayani ribuan pelanggan.
          </p>
          <p class="text-gray-600 mb-6">
            Kami fokus memberikan solusi terbaik untuk setiap masalah perangkat Apple Anda, dengan teknisi yang berpengalaman dan sparepart original berkualitas.
          </p>
        </div>
        <div class="bg-gradient-to-br from-blue-500 to-purple-600 rounded-3xl h-96"></div>
      </div>
    </div>
  </section>

  <!-- Why Us Component -->
  <WhyUs />

  <!-- Visi Misi -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Visi Kami</h3>
          <p class="text-gray-600">
            Menjadi service center MacBook & iMac paling terpercaya di Yogyakarta, dikenal dengan kualitas service, kejujuran, dan kepuasan pelanggan.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Misi Kami</h3>
          <p class="text-gray-600">
            Memberikan layanan service terbaik dengan harga fair, menggunakan sparepart berkualitas, dan memastikan setiap pelanggan puas dengan hasil perbaikan.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-blue-600">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
        Percayakan MacBook Anda Pada Kami
      </h2>
      <p class="text-xl text-blue-100 mb-8">
        Hubungi kami untuk konsultasi gratis dan solusi terbaik untuk MacBook Anda
      </p>
      <a href="/kontak" class="inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded-full text-blue-600 bg-white hover:bg-gray-100 transition-colors">
        Hubungi Kami
      </a>
    </div>
  </section>

  <Footer />
  <WhatsAppButton />

  <!-- Organization Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "KyuuMac",
    "alternateName": "Kyuu Mac Service MacBook Jogja",
    "url": "https://kyuumac.com",
    "logo": "https://kyuumac.com/favicon.svg",
    "description": "KyuuMac adalah pusat servis MacBook & iMac terpercaya di Jogja sejak 2020. Spesialis perbaikan mati total, ganti sparepart original, dan jual beli MacBook bekas berkualitas dengan garansi 1 bulan.",
    "telephone": "+6285117101318",
    "email": "kyuumac@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Yogyakarta",
      "addressRegion": "DI Yogyakarta",
      "addressCountry": "ID"
    },
    "sameAs": [
      "https://www.instagram.com/kyuumac",
      "https://www.tiktok.com/@kyuumac",
      "https://maps.app.goo.gl/AAsShsuNsJNBXXS39"
    ]
  }
  </script>
</Layout>
