---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { 
  title, 
  description = "KyuuMac - Pusat Service Macbook & iMac Terpercaya di Jogja. Spesialis perbaikan mati total, ganti sparepart (LCD, keyboard, trackpad, baterai) dan jual beli MacBook bekas berkualitas.",
  canonical
} = Astro.props;

// Get canonical URL - remove trailing slash
const baseUrl = "https://kyuumac.com";
const path = Astro.url.pathname.replace(/\/$/, ''); // Remove trailing slash
const canonicalURL = canonical || `${baseUrl}${path}`;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL (no trailing slash) -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="servis macbook jogja, service macbook jogja, service imac jogja, macbook mati total, ganti lcd macbook, ganti keyboard macbook, ganti baterai macbook, jual beli macbook bekas jogja, repair macbook yogyakarta, kyuumac" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="KyuuMac" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <!-- Local Business Schema - Enhanced -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": `${baseUrl}/#organization`,
      "name": "KyuuMac",
      "image": `${baseUrl}/favicon.svg`,
      "url": baseUrl,
      "telephone": "+6285117101318",
      "priceRange": "Rp 100.000 - Rp 10.000.000",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Yogyakarta",
        "addressLocality": "Yogyakarta",
        "addressRegion": "DI Yogyakarta",
        "postalCode": "55000",
        "addressCountry": "ID"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -7.7956,
        "longitude": 110.3695
      },
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "latitude": -7.7956,
          "longitude": 110.3695
        },
        "geoRadius": "20000"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday"],
          "opens": "09:00",
          "closes": "21:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Friday",
          "opens": "13:30",
          "closes": "21:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Saturday", "Sunday"],
          "opens": "09:00",
          "closes": "21:00"
        }
      ],
      "sameAs": [
        "https://www.instagram.com/kyuumac",
        "https://www.tiktok.com/@kyuumac"
      ],
      "serviceType": [
        "Servis MacBook",
        "Perbaikan MacBook",
        "Ganti Sparepart MacBook",
        "Jual Beli MacBook Bekas"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Layanan Service MacBook",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Servis MacBook Mati Total",
              "description": "Perbaikan MacBook yang mati total, tidak mau menyala"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Ganti LCD Retina MacBook",
              "description": "Penggantian layar LCD Retina MacBook yang pecah atau bergaris"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Ganti Keyboard MacBook",
              "description": "Penggantian keyboard MacBook yang rusak atau tidak berfungsi"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Ganti Baterai MacBook",
              "description": "Penggantian baterai MacBook yang sudah lemah atau bocor"
            }
          }
        ]
      }
    })} />
  </head>
  <body class="bg-white text-gray-900">
    <slot />
  </body>
</html>
